{
    "name": "survos/ai-pipeline-bundle",
    "description": "Symfony bundle for resumable, ordered AI task pipelines — OCR, classify, describe, extract, summarize, and more, out of the box.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": ["symfony", "symfony-ux", "ai", "pipeline", "ocr", "vision", "llm", "openai", "mistral", "ux"],
    "autoload": {
        "psr-4": {
            "Survos\\AiPipelineBundle\\": "src/"
        }
    },
    "require": {
        "php": "^8.4",
        "symfony/framework-bundle": "^8.0",
        "symfony/http-client": "^8.0",
        "symfony/twig-bundle": "^8.0",
        "twig/twig": "^3.0",
        "symfony/ai-bundle": "^0.8",
        "symfony/ai-agent": "^0.8",
        "symfony/ai-open-ai-platform": "^0.8",
        "symfony/ai-mistral-platform": "^0.8",
        "survos/core-bundle": "^2.0",
        "doctrine/orm": "^3.6",
        "symfony/messenger": "^8.0",
        "symfony/uid": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0|^12.0|^13.0",
        "lunetics/llm-cost-tracking-bundle": "^0.3.0"
    },
    "extra": {
        "symfony": {
            "require": "^8.0"
        }
    }
}
